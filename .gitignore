# ==========================================
# Dependency directories
frontend/node_modules/
node_modules/
/.pnp
.pnp.js

# Testing and Coverage
coverage/
frontend/coverage/

# Production build directories (even if not deploying, good to have)
frontend/build/
frontend/dist/
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc React/Vite
.eslintcache
.vite/

# ==========================================
