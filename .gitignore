# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
.venv/
env.bak/
venv.bak/

# FastAPI / Python Logs and Databases
*.log
*.sqlite3
*.db

# Testing
.pytest_cache/
.tox/
.coverage
htmlcov/

# Python packaging/distribution
dist/
build/
*.egg-info/

